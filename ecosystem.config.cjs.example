/**
 * PM2 config for LT-IDP. Copy to ecosystem.config.cjs and adjust if needed.
 * Start with: pm2 start ecosystem.config.cjs
 */
module.exports = {
  apps: [{
    name: 'lt-idp',
    script: 'dist-server/server/index.js',
    cwd: __dirname,
    env: {
      PORT: process.env.PORT || 3001,
      DATA_DIR: process.env.DATA_DIR || __dirname + '/data',
      NODE_ENV: 'production',
    },
    instances: 1,
    autorestart: true,
    watch: false,
    max_memory_restart: '500M',
  }],
};
