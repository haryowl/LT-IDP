{
  "name": "iot-scada-client",
  "version": "1.0.0",
  "description": "A cross-platform desktop application for industrial IoT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:app": "electron-builder",
    "start": "electron .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:server": "tsc -p server/tsconfig.json",
    "start:web": "node dist-server/server/index.js",
    "dev:web": "concurrently \"npm run dev:vite\" \"npx tsx server/index.ts\"",
    "build:web": "npm run build:vite && npm run build:server"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.19",
    "@mui/material": "^5.14.20",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.2.2",
    "date-fns": "^2.30.0",
    "jsonwebtoken": "^9.0.2",
    "modbus-serial": "^8.0.16",
    "mqtt": "^5.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "serialport": "^12.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.2.0",
    "jsdom": "^23.0.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0"
  },
  "build": {
    "appId": "com.iot-scada.client",
    "productName": "IoT SCADA Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    }
  }
}

